# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
venv/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
# .env.example is intentionally tracked

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
*.DS_Store

# ── Runtime / Generated outputs ───────────────────────────────────────────────
analysis_output/
vector_db/

# ── Data (audio files and processed outputs are regenerable) ──────────────────
data/uploads/
data/raw/
data/processed/
data/*.jsonl

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Large binary files ────────────────────────────────────────────────────────
*.zip
*.wav
*.mp3
*.mp4
*.m4a
*.flac
